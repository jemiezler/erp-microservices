# API Gateway Environment Configuration
# Copy to .env and update for your environment

# =====================
# Gateway Configuration
# =====================
GATEWAY_PORT=8080
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# =====================
# Backend Service URLs
# =====================
# These should point to internal service addresses (not exposed to internet)
HR_SERVICE_URL=http://localhost:8081
FINANCE_SERVICE_URL=http://localhost:8082
AUTH_SERVICE_URL=http://localhost:8083

# =====================
# Database Configuration
# =====================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=erp_db
DB_SSL_MODE=disable

# =====================
# Logging
# =====================
LOG_LEVEL=info
LOG_FORMAT=json
